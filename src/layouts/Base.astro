---
export interface Props {
  title?: string;
}
const { title = "Refinery Ops Dashboard" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-[#060912] text-white overflow-x-hidden">
    <slot />
  </body>
</html>